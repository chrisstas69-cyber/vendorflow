# === VendorFlow — Airtable (server-side only) ===
AIRTABLE_PAT=
AIRTABLE_BASE_ID=

# === Event scraper — Google Sheets export (optional) ===
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SPREADSHEET_ID=

# === Daily email digest (optional) ===
GMAIL_FROM=
GMAIL_APP_PASSWORD=
GMAIL_TO=

# === Cron protection (Vercel) ===
CRON_SECRET=

# === App ===
NEXT_PUBLIC_BASE_URL=http://localhost:3002

# === Platform database (Neon Postgres — see docs/DATABASE-NEON.md) ===
# Pooled URL for runtime (serverless):
DATABASE_URL="postgresql://USER:PASS@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require"
# Direct URL for migrations:
DIRECT_URL="postgresql://USER:PASS@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# === Pilot mode (Founders Edition) ===
# seed = in-memory (resets on Vercel cold start) | db = Neon Postgres
PILOT_DATA_SOURCE=db
PILOT_MODE=true
