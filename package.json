{
  "name": "vendorflow",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "dev:clean": "lsof -ti:3002 | xargs kill -9 2>/dev/null; rm -rf .next && next dev -p 3002",
    "dev:fresh": "lsof -ti:3002 | xargs kill -9 2>/dev/null; rm -rf .next node_modules/.cache && next dev -p 3002",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed-hosted": "tsx scripts/seed-hosted-db.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "airtable:setup": "python3 scripts/setup-airtable.py",
    "airtable:verify": "python3 scripts/verify-airtable.py"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.487.0",
    "next": "14.2.35",
    "nodemailer": "^8.0.3",
    "react": "^18",
    "react-dom": "^18",
    "tailwind-merge": "^3.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "postcss": "^8",
    "prisma": "^6.9.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
