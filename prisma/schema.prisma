// VendorFlow platform database — Neon Postgres in production; scraper uses separate SQLite (data/events.db)
// Setup: docs/DATABASE-NEON.md  |  Production schema: npm run db:migrate:deploy

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Organizer tenancy & workflow backbone ───────────────────────────────────

model OrganizerAccount {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  slug         String   @unique
  name         String
  email        String   @unique
  organization String
  region       String?  // nassau | suffolk | nyc | nj
  verified     Boolean  @default(false)
  planId       String   @default("org-founders")

  applications   VendorApplication[]
  boothMaps      BoothMap[]
  activityFeed   ActivityFeedItem[]
  auditLogs      AuditLog[]
  notifications  Notification[]
  eventTimelines EventTimeline[]
  galleryItems   GalleryItem[]

  @@index([slug])
}

model VendorApplication {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizerId String
  organizer   OrganizerAccount @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  eventId   String
  eventName String
  seriesId  String?

  vendorEmail  String
  vendorName   String
  category     String
  message      String @default("")

  status        String  @default("pending") // pending | approved | rejected
  pipelineStage String  @default("applied") // scraped | applied | reviewing | approved | waitlisted
  shortlisted   Boolean @default(false)
  infoRequested Boolean @default(false)

  requiredForms    String @default("[]") // JSON string[]
  uploadedDocTypes String @default("[]") // JSON string[]
  setupPhotoUrl    String?
  hasInsurance     Boolean @default(false)

  paymentStatus  String @default("none") // none | invoiced | partial | paid
  contractStatus String @default("unsigned") // unsigned | sent | signed

  internalNotes String @default("")

  passportId String?
  passport   VendorPassport? @relation(fields: [passportId], references: [id], onDelete: SetNull)

  boothAssignment BoothAssignment?
  auditLogs       AuditLog[]

  @@index([organizerId, eventId])
  @@index([organizerId, status])
  @@index([vendorEmail])
}

model BoothMap {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizerId String
  organizer   OrganizerAccount @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  eventId     String
  name        String @default("Main grid")
  layoutMode  String @default("grid")
  /// JSON BoothCell[] — label, utilities, optional pre-assignment hints
  gridJson    String @default("[]")
  /// JSON StreetFairLayoutDefinition for street-fair mode
  streetFairJson String @default("{}")

  assignments BoothAssignment[]

  @@unique([organizerId, eventId])
}

model BoothAssignment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  boothMapId  String
  boothMap    BoothMap @relation(fields: [boothMapId], references: [id], onDelete: Cascade)
  boothLabel  String

  applicationId String?           @unique
  application   VendorApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  vendorEmail String
  vendorName  String
  utilities   String @default("[]") // JSON ('electric' | 'water')[]

  @@unique([boothMapId, boothLabel])
  @@index([vendorEmail])
}

model EventTimeline {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizerId  String
  organizer    OrganizerAccount @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  eventId      String
  currentStage String @default("planning")
  /// JSON EventTimelineStageState[]
  stagesJson   String @default("[]")

  @@unique([organizerId, eventId])
}

model ActivityFeedItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  organizerId String
  organizer   OrganizerAccount @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  eventType   String // application.submitted | booth.assigned | …
  actorType   String // organizer | vendor | system
  actorId     String?
  actorLabel  String?

  targetType  String // application | booth | contract | payment | event
  targetId    String?
  targetLabel String?

  title    String
  summary  String?
  metadata String @default("{}")
  readAt   DateTime?
  eventId  String?

  @@index([organizerId, createdAt])
  @@index([organizerId, readAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  organizerId String
  organizer   OrganizerAccount @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  action     String
  entityType String
  entityId   String
  actorId    String?
  actorLabel String?
  beforeJson String?
  afterJson  String?
  metadata   String @default("{}")

  applicationId String?
  application   VendorApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([organizerId, createdAt])
  @@index([entityType, entityId])
}

model Notification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizerId String
  organizer   OrganizerAccount @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  channel  String @default("in_app") // in_app | email
  status   String @default("pending") // pending | sent | read | failed
  eventType String
  title    String
  body     String
  metadata String @default("{}")
  readAt   DateTime?

  @@index([organizerId, status])
}

// ─── Vendor Passport ─────────────────────────────────────────────────────────

model VendorPassport {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendorEmail  String  @unique
  businessName String  @default("")
  dba          String?
  contactName  String  @default("")
  phone        String  @default("")
  website      String?
  description  String  @default("")

  /// JSON string[] — product / service categories
  categories  String @default("[]")
  /// JSON string[] — AI matching tags (family-friendly, needs-20a-power, …)
  serviceTags String @default("[]")

  // Document compliance
  validationState String    @default("incomplete") // incomplete | documents_pending | needs_review | ready_for_matching
  complianceScore Int       @default(0)
  insuranceExpiry DateTime?
  setupPhotoUrl   String?
  planId          String    @default("vendor-free")

  // Trailer & booth logistics
  vehicleType      String  @default("tent-only") // tent-only | van | trailer | food-truck | other
  trailerLengthFt  Float?
  boothWidthFt     Float?
  boothDepthFt     Float?
  needsElectric    Boolean @default(false)
  ampRequirement   String?
  setupTimeMinutes Int?
  waterAccess      Boolean?
  generatorOk      Boolean?

  documents VendorDocument[]
  invoices  Invoice[]
  applications VendorApplication[]
  galleryItems GalleryItem[]
  debriefs     EventDebrief[]
  financials   VendorFinancial[]
  receipts     VendorReceipt[]

  @@index([validationState])
}

model EventDebrief {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendorPassportId String?
  passport         VendorPassport? @relation(fields: [vendorPassportId], references: [id], onDelete: Cascade)
  vendorEmail      String

  eventId       String?
  applicationId String?
  eventName     String
  eventDate     String
  status        String @default("booked")

  notes               String @default("")
  issues              String @default("")
  bringNextTime       String @default("")
  missedOpportunities String @default("")
  topSellers          String @default("")
  crowdRating         Int?

  weatherSummary   String?
  weatherHighF     Int?
  weatherLowF      Int?
  weatherPrecipPct Int?
  weatherCondition String?

  checklistJson String @default("[]")

  grossSalesCents Int?
  expensesCents   Int?
  netProfitCents  Int?
  marginBps       Int?
  breakEvenHour   String?
  bestHour        String?
  cashPercent     Int?
  cardPercent     Int?
  financialId     String?

  @@unique([vendorEmail, eventName, eventDate])
  @@index([vendorEmail, eventDate])
  @@index([vendorPassportId])
}

model VendorFinancial {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendorPassportId String?
  passport         VendorPassport? @relation(fields: [vendorPassportId], references: [id], onDelete: Cascade)
  vendorEmail      String

  eventId   String?
  eventName String
  eventDate String

  grossSalesCents Int
  expensesCents   Int
  netProfitCents  Int
  marginBps       Int
  breakEvenHour   String?
  bestHour        String?
  cashPercent     Int?
  cardPercent     Int?
  source          String @default("import")

  @@unique([vendorEmail, eventName, eventDate])
  @@index([vendorEmail, eventDate])
}

model VendorReceipt {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  vendorPassportId String?
  passport         VendorPassport? @relation(fields: [vendorPassportId], references: [id], onDelete: Cascade)
  vendorEmail      String

  category    String
  amountCents Int    @default(0)
  fileName    String?
  imageData   String?
  notes       String @default("")

  @@index([vendorEmail])
}

model MagicLinkToken {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  email     String
  role      String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?

  @@index([email])
}

model VendorDocument {
  id         String   @id @default(cuid())
  uploadedAt DateTime @default(now())

  passportId String
  passport   VendorPassport @relation(fields: [passportId], references: [id], onDelete: Cascade)

  type      String // coi | w9 | ce200 | booth-layout | vehicle-info | food-permit | other
  fileName  String
  fileUrl   String?
  status    String    @default("pending") // pending | approved | rejected | expired
  expiresAt DateTime?
  notes     String?

  @@index([passportId, type])
}

// ─── Event Series ────────────────────────────────────────────────────────────

model EventSeries {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  slug          String  @unique
  name          String
  description   String  @default("")
  organizerId   String
  seasonLabel   String?
  coverImageUrl String?

  events   SeriesEvent[]
  invoices Invoice[]

  @@index([organizerId])
}

model SeriesEvent {
  id       String @id @default(cuid())
  seriesId String
  series   EventSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  eventId  String

  @@unique([seriesId, eventId])
  @@index([eventId])
}

// ─── Payments & Contracts ────────────────────────────────────────────────────

model PaymentAccount {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerType String // vendor | organizer | platform
  ownerId   String
  provider  String @default("stripe") // stripe | manual

  externalAccountId String?
  displayName       String?
  onboardingStatus  String  @default("pending") // pending | in_progress | complete | restricted
  payoutEnabled     Boolean @default(false)
  /// JSON — provider-specific metadata (Connect account id, last webhook, …)
  metadata          String  @default("{}")

  splits PaymentSplit[]

  @@unique([ownerType, ownerId, provider])
  @@index([ownerId])
}

model Invoice {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoiceNumber String @unique
  status        String @default("draft") // draft | sent | partial | paid | void | overdue

  organizerId      String
  eventId          String?
  seriesId         String?
  vendorPassportId String?

  series   EventSeries?    @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  vendor   VendorPassport? @relation(fields: [vendorPassportId], references: [id], onDelete: SetNull)

  totalAmountCents Int      @default(0)
  currency         String   @default("usd")
  dueDate          DateTime?
  paidAt           DateTime?
  notes            String?

  lineItems InvoiceLineItem[]
  splits    PaymentSplit[]
  payments  Payment[]
  contracts Contract[]

  @@index([organizerId, status])
  @@index([eventId])
  @@index([vendorPassportId])
}

model InvoiceLineItem {
  id        String @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  label       String
  description String?
  amountCents Int
  quantity    Int     @default(1)
  sortOrder   Int     @default(0)

  @@index([invoiceId])
}

model PaymentSplit {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  payeeAccountId String?
  payeeAccount   PaymentAccount? @relation(fields: [payeeAccountId], references: [id], onDelete: SetNull)

  payeeType  String // vendor | organizer | platform | sponsor
  payeeLabel String?

  /// Fixed allocation in cents — use when not percentage-based
  amountCents Int?
  /// Basis points (1500 = 15.00%) — use for proportional splits
  percentBps  Int?

  status    String    @default("pending") // pending | processing | paid | failed | waived
  paidAt    DateTime?
  externalTransferId String?

  @@index([invoiceId])
  @@index([payeeAccountId])
}

model Payment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  amountCents       Int
  currency          String  @default("usd")
  status            String  @default("pending") // pending | processing | succeeded | failed | refunded
  provider          String  @default("stripe")
  externalPaymentId String?
  paymentMethod     String?
  milestoneId       String?
  /// JSON — checkout session, receipt, failure reason
  metadata          String  @default("{}")

  @@index([invoiceId, status])
  @@index([externalPaymentId])
}

model ContractTemplate {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  slug              String  @unique
  name              String
  description       String  @default("")
  bodyTemplate      String
  /// JSON PaymentMilestone[] — e.g. 50% deposit, 50% balance 30 days out
  defaultMilestones String  @default("[]")
  isActive          Boolean @default(true)

  contracts Contract[]
}

model Contract {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  templateId String
  template   ContractTemplate @relation(fields: [templateId], references: [id])

  invoiceId        String?
  invoice          Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  vendorPassportId String
  organizerId      String
  eventId          String?

  status String @default("draft") // draft | sent | signed_vendor | signed_organizer | active | cancelled
  /// JSON resolved milestone schedule with due dates
  milestones       String @default("[]")
  documentBody     String @default("")
  signedAtVendor   DateTime?
  signedAtOrganizer DateTime?
  documentUrl      String?

  @@index([vendorPassportId])
  @@index([organizerId, status])
}

// ─── Long Island / Regional Compliance ───────────────────────────────────────

model ComplianceRule {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  region              String // nassau | suffolk | nyc | nj
  documentType        String
  label               String
  description         String  @default("")
  /// JSON string[] — event categories this applies to; empty = all
  requiredForCategories String @default("[]")
  salesTaxRateBps     Int?
  permitTemplateUrl   String?
  isFoundersEdition   Boolean @default(false)

  @@index([region, documentType])
}

// ─── AI Intelligence Cache ───────────────────────────────────────────────────

model AIInsight {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scopeType String // vendor | event | series | organizer | match
  scopeId   String

  insightType String // match_recommendation | revenue_forecast | compliance_alert | assistant_reply | risk_score
  title       String
  summary     String
  /// JSON — structured payload for UI components (scores, event ids, actions, …)
  payload     String @default("{}")

  modelVersion String?
  confidence   Float?
  status       String    @default("active") // active | dismissed | expired
  expiresAt    DateTime?

  @@index([scopeType, scopeId, status])
  @@index([insightType, status])
  @@index([expiresAt])
}

// ─── Trust galleries (events, organizers, vendors) ───────────────────────────

model GalleryItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// event | organizer | vendor
  entityType String
  /// event id, organizer id, or vendor email
  entityId   String

  imageUrl  String
  caption   String?
  /// JSON GalleryTag[] — crowd, booth, food, setup, branding, family, night, kids-zone
  tags      String  @default("[]")
  sortOrder Int     @default(0)
  isCover   Boolean @default(false)
  isPublic  Boolean @default(true)

  organizerId String?
  organizer   OrganizerAccount? @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  passportId  String?
  passport    VendorPassport?   @relation(fields: [passportId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([entityType, entityId, isPublic])
  @@index([organizerId])
  @@index([passportId])
}

// ─── Operational contact intelligence (private — not public directory) ───────

model Jurisdiction {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name   String
  slug   String @unique
  county String? // nassau | suffolk
  town   String?
  region String @default("long-island") // long-island | nyc | nj
  state  String @default("NY")

  organizations OpsOrganization[]

  @@index([county, town])
  @@index([region])
}

model OpsOrganization {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// chamber | bid | town-office | village-office | parks-rec | market-operator | …
  type     String
  name     String
  website  String?
  publicPhone String?
  publicEmail String?
  address  String?

  jurisdictionId String?
  jurisdiction   Jurisdiction? @relation(fields: [jurisdictionId], references: [id], onDelete: SetNull)
  /// JSON string[] — towns/villages covered beyond primary jurisdiction
  jurisdictionCoverage String @default("[]")

  notes               String @default("")
  /// JSON string[] — street-fair, festival, farmers-market, …
  recurringEventTypes String @default("[]")
  vendorHeavy         Boolean @default(false)
  fitScore            Int     @default(0) // 0–100 VendorFlow fit
  internalOnly        Boolean @default(true)
  /// lead | researching | contacted | meeting-booked | pilot-candidate | active
  outreachStatus      String  @default("lead")
  /// internal | organizer-only | approved-vendor | all-paying-clients
  defaultVisibility   String  @default("internal")

  /// Import / dedupe identity (internal intelligence layer)
  canonicalName     String?
  normalizedDomain  String?
  dedupeKey         String?  @unique
  county            String?  // denormalized for filters/dedup
  town              String?
  /// manual | tracker | legacy
  sourceSystem      String?
  sourceFile        String?
  sourceUrl         String?
  sourcePriority    Int      @default(50)
  lastImportedAt    DateTime?
  lastSeenAt        DateTime?
  importRunId       String?
  manuallyEdited    Boolean  @default(false)

  contacts         OpsContact[]
  eventProfiles    OrganizationEventProfile[]
  outreachActivities OutreachActivity[]

  @@index([type])
  @@index([jurisdictionId])
  @@index([outreachStatus])
  @@index([internalOnly])
  @@index([sourceSystem])
  @@index([dedupeKey])
  @@index([normalizedDomain])
}

model OpsContact {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   OpsOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name       String
  title      String?
  phone      String?
  email      String?
  linkedIn   String?
  department String?
  /// email | phone | linkedin
  preferredContactMethod String @default("email")
  /// JSON ContactPurposeTag[]
  purposeTags String @default("[]")
  /// internal | organizer-only | approved-vendor | all-paying-clients
  visibility  String @default("organizer-only")
  notes       String @default("")
  internalNotes String @default("")

  outreachActivities OutreachActivity[]

  @@index([organizationId])
  @@index([visibility])
}

model OrganizationEventProfile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   OpsOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  eventDistrict      String?
  /// JSON string[]
  eventTypes         String @default("[]")
  seasonality        String?
  typicalVendorCount Int?
  notes              String @default("")

  @@index([organizationId])
}

model OutreachActivity {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  organizationId String?
  organization   OpsOrganization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contactId      String?
  contact        OpsContact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)

  /// call | email | meeting | note | research
  activityType String
  summary      String
  actorLabel   String?
  metadata     String @default("{}")

  @@index([organizationId, createdAt])
  @@index([contactId, createdAt])
}

/// Audit trail for chamber/contact CSV imports
model ImportRun {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  sourceSystem  String
  sourceFile    String?
  dryRun        Boolean @default(false)
  /// preview | completed | failed
  status        String  @default("preview")
  rowsProcessed Int     @default(0)
  createdCount  Int     @default(0)
  updatedCount  Int     @default(0)
  skippedCount  Int     @default(0)
  conflictCount Int     @default(0)
  errorCount    Int     @default(0)
  /// JSON ImportRunSummary — row-level preview/errors
  summaryJson   String  @default("{}")
  actorLabel    String?

  @@index([createdAt])
  @@index([sourceSystem])
}

/// Runtime health for scrape sources (tracker registry mirror)
model ScrapeSourceHealth {
  id        String   @id
  updatedAt DateTime @updatedAt

  name           String
  /// active | inactive | degraded | unknown
  status         String  @default("unknown")
  active         Boolean @default(true)
  lastCheckedAt  DateTime?
  lastSuccessAt  DateTime?
  lastFailureAt  DateTime?
  lastError      String?
  outputCount    Int?
  region         String?
  category       String?

  @@index([status])
  @@index([active])
}
